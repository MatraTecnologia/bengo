---
import { heroSelos, site } from '../data/content';
---

<section class="hero" id="topo">
  <img
    class="hero__foto"
    src="/images/loja-salao.webp"
    srcset="/images/loja-salao-768.webp 768w, /images/loja-salao-1024.webp 1024w, /images/loja-salao-1536.webp 1536w, /images/loja-salao.webp 1920w"
    sizes="100vw"
    alt="Interior de uma loja da franquia Bengô Açaí"
    width="1920"
    height="1440"
    loading="eager"
    decoding="async"
  />
  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__conteudo">
      <span class="eyebrow eyebrow--claro">Franquia de açaí · O Ouro Roxo</span>

      <h1 class="hero__titulo">
        Fature até <span class="hero__valor">R$ 1,3 milhão</span> ao ano com uma franquia Bengô Açaí
      </h1>

      <p class="hero__sub">
        Entre na rede de açaí que mais cresce no Brasil: fabricação e logística próprias, modelo
        comprovado e suporte completo do primeiro contato à inauguração.
      </p>

      <div class="hero__acoes">
        <a href="#quiz" class="btn btn--primario" data-quiz-open>Descubra seu perfil de franqueado</a>
        <a href={site.whatsapp} class="btn btn--wpp" target="_blank" rel="noopener">Falar no WhatsApp</a>
      </div>

      <dl class="hero__selos">
        {
          heroSelos.map((selo) => (
            <div class="hero__selo">
              <dt class="hero__selo-num">{selo.valor}</dt>
              <dd class="hero__selo-rot">{selo.rotulo}</dd>
            </div>
          ))
        }
        <div class="hero__selo">
          <dt class="hero__selo-num">25%</dt>
          <dd class="hero__selo-rot">margem de lucro</dd>
        </div>
      </dl>
    </div>

    <div class="hero__midia" aria-hidden="true">
      <img
        class="hero__pote"
        src="/acai-apresentativo.webp"
        alt=""
        width="1365"
        height="1073"
        fetchpriority="high"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--acai-900);
    color: var(--branco);
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: min(86vh, 760px);
    padding-block: clamp(2.5rem, 1.8rem + 4vw, 4.5rem);
  }

  .hero__foto {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(118deg, rgba(64, 0, 78, 0.95) 0%, rgba(64, 0, 78, 0.82) 46%, rgba(74, 12, 88, 0.55) 100%),
      linear-gradient(180deg, transparent 60%, rgba(24, 0, 30, 0.5) 100%);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: grid;
    gap: clamp(2rem, 1rem + 3vw, 3.5rem);
    align-items: center;
  }

  .hero__titulo {
    font-size: clamp(2rem, 1.3rem + 2.6vw, 3.4rem);
    line-height: 1.06;
    margin-block: 1rem 1.2rem;
    max-width: 15ch;
    text-shadow: 0 2px 24px rgba(24, 0, 30, 0.35);
  }

  .hero__valor {
    background: var(--grad-numero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__sub {
    font-size: var(--t-lead);
    color: rgba(255, 255, 255, 0.9);
    max-width: 46ch;
    line-height: 1.55;
    text-shadow: 0 1px 16px rgba(24, 0, 30, 0.3);
  }

  .hero__acoes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.8rem;
  }

  .hero__selos {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 1rem + 2vw, 3rem);
    margin-top: 2.2rem;
    padding-top: 1.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.22);
  }

  .hero__selo-num {
    font-size: clamp(1.9rem, 1.4rem + 2vw, 2.6rem);
    font-weight: var(--peso-black);
    letter-spacing: -0.03em;
    line-height: 1;
    background: var(--grad-numero);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__selo-rot {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.82);
    margin-top: 0.35rem;
  }

  .hero__midia {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__pote {
    width: 100%;
    max-width: 380px;
    height: auto;
    filter: drop-shadow(0 22px 40px rgba(24, 0, 30, 0.5));
    animation: flutuar 5.5s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes flutuar {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 0.82fr 1.18fr;
    }
    .hero__midia {
      justify-content: flex-end;
    }
    .hero__pote {
      max-width: 860px;
      margin-right: clamp(-90px, -4vw, 0px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__pote {
      animation: none;
    }
  }
</style>
