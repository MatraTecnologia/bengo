---
import { diferenciais } from '../data/content';
import fabrica from '../assets/icons/fabricacao.svg?raw';
import caminhao from '../assets/icons/logistica.svg?raw';
import tigela from '../assets/icons/acompanhamentos.svg?raw';
import grafico from '../assets/icons/modelo.svg?raw';
import suporte from '../assets/icons/suporte.svg?raw';
import loja from '../assets/icons/lojas.svg?raw';

const icones = { fabrica, caminhao, tigela, grafico, suporte, loja };
---

<section class="dif secao" id="diferenciais">
  <div class="container">
    <div class="dif__topo reveal">
      <div class="cabecalho-secao dif__intro">
        <span class="eyebrow">Por que Bengô</span>
        <h2 class="titulo-secao">O que torna a Bengô Açaí uma franquia mais segura</h2>
        <p class="lead">
          Não é só uma marca de açaí: é uma estrutura completa por trás de cada loja, pensada para
          reduzir o risco do franqueado e sustentar o crescimento.
        </p>
      </div>

      <figure class="dif__foto">
        <img
          src="/images/loja-salao-1024.webp"
          srcset="/images/loja-salao-768.webp 768w, /images/loja-salao-1024.webp 1024w, /images/loja-salao-1536.webp 1536w"
          sizes="(min-width: 940px) 42vw, 90vw"
          alt="Salão interno de uma loja franqueada Bengô Açaí com design moderno em roxo e verde"
          width="1024"
          height="768"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>

    <div class="dif__grid">
      {
        diferenciais.map((d) => (
          <article class="dif__card reveal">
            <span class="dif__icone" aria-hidden="true" set:html={icones[d.icone]} />
            <h3 class="dif__titulo">{d.titulo}</h3>
            <p class="dif__texto">{d.texto}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .dif__topo {
    display: grid;
    gap: clamp(1.5rem, 1rem + 2vw, 3rem);
    align-items: center;
    margin-bottom: clamp(2.25rem, 1.6rem + 2vw, 3.5rem);
  }

  .dif__intro {
    margin-bottom: 0;
  }

  .dif__foto {
    margin: 0;
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--sombra-md);
  }

  .dif__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  .dif__grid {
    display: grid;
    gap: var(--gap);
    grid-template-columns: 1fr;
  }

  .dif__card {
    background: var(--branco);
    border: 1px solid var(--borda);
    border-radius: var(--r-lg);
    padding: clamp(1.5rem, 1.2rem + 1vw, 2rem);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .dif__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--sombra-md);
    border-color: transparent;
  }

  .dif__icone {
    display: inline-grid;
    place-items: center;
    width: 58px;
    height: 58px;
    border-radius: 16px;
    background: linear-gradient(140deg, rgba(113, 0, 78, 0.1), rgba(151, 206, 38, 0.12));
    color: var(--acai-700);
    margin-bottom: 1.1rem;
  }

  .dif__icone :global(svg) {
    width: 30px;
    height: 30px;
    fill: currentColor;
  }

  .dif__titulo {
    font-size: var(--t-h3);
    font-weight: var(--peso-bold);
  }

  .dif__texto {
    color: var(--ink-suave);
    margin-top: 0.6rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (min-width: 640px) {
    .dif__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 940px) {
    .dif__topo {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  @media (min-width: 980px) {
    .dif__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
